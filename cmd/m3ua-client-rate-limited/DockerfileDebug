FROM golang:1.23-alpine3.21 AS build-env
RUN go install github.com/go-delve/delve/cmd/dlv@latest
WORKDIR /hstplib
COPY hstplib .
RUN go mod download
WORKDIR /stp
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/m3ua-client-rate-limited cmd/m3ua-client-rate-limited
WORKDIR /stp/cmd/m3ua-client-rate-limited
RUN go build -gcflags="all=-N -l" .

FROM alpine:3.21
EXPOSE 40000
LABEL maintainer="igor.sabo@horisen.com"
LABEL date="2025-02-24"
LABEL description="Initial"
LABEL version="1.0"
COPY --from=build-env /go/bin/dlv /
COPY --from=build-env /stp/cmd/m3ua-client-rate-limited/m3ua-client-rate-limited /usr/bin/m3ua-client-rate-limited
RUN chmod +x /usr/bin/m3ua-client-rate-limited
WORKDIR /usr/bin
ENTRYPOINT ["/dlv", "--listen=:40000", "--headless=true", "--api-version=2", "--accept-multiclient", "exec", "./m3ua-client-rate-limited"]